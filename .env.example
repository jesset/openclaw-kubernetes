# OpenClaw Azure Setup Configuration
# Copy to .env and fill in your values: cp .env.example .env
# Lines starting with # are ignored. Env vars override .env values.

# ── Azure / AKS ─────────────────────────────────────────────────────────────
# SUBSCRIPTION=
# CLUSTER_NAME=openclaw
# RESOURCE_GROUP=openclaw-rg
# LOCATION=westus2
# NODE_VM_SIZE=Standard_D4s_v3
# NODE_COUNT=1
# K8S_VERSION=
# SKIP_CLUSTER=false

# ── Workload Identity ────────────────────────────────────────────────────────
# Creates a managed identity with federated credential for the pod.
# WORKLOAD_IDENTITY=false
# WORKLOAD_IDENTITY_ROLE=Contributor
# WORKLOAD_IDENTITY_SCOPE=/subscriptions/<sub-id>/resourcegroups/<rg-name>

# ── Gateway ──────────────────────────────────────────────────────────────────
# Auto-generated if empty. Save it after first run.
# GATEWAY_TOKEN=

# ── Messaging ────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── LiteLLM / Model Provider ────────────────────────────────────────────────
# Provider: github_copilot (default, no key needed), anthropic, openai
# LITELLM_PROVIDER=github_copilot
# LITELLM_API_KEY=
# LITELLM_API_BASE=
# LITELLM_MODEL=claude-opus-4.6

# ── Memory Search / Embeddings ───────────────────────────────────────────────
# Set EMBEDDING_API_KEY to enable semantic memory search
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# PERSISTENCE_SIZE=100Gi

# ── Helm ─────────────────────────────────────────────────────────────────────
# Chart source: "oci" (from GHCR) or "local" (from project directory)
# CHART_SOURCE=oci

# ── Debug ────────────────────────────────────────────────────────────────────
# DRY_RUN=false
